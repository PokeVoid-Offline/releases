From d424ac1ea6119ab6b005b1270a0c249e38dc6a8c Mon Sep 17 00:00:00 2001
From: Scooom <me@scooom.xyz>
Date: Sat, 4 Apr 2026 14:52:55 -0500
Subject: [PATCH 4/4] Correctly detect iPad

---
 src/touch-controls.ts | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/src/touch-controls.ts b/src/touch-controls.ts
index f0d65daa1d41..8f0192808281 100644
--- a/src/touch-controls.ts
+++ b/src/touch-controls.ts
@@ -259,5 +259,7 @@ export function isMobile(): boolean {
 export function isIOS(): boolean {
   const userAgent = navigator.userAgent || navigator.vendor || (window as any)["opera"];
   // Check for iPhone, iPad, or iPod
-  return /iPad|iPhone|iPod/.test(userAgent) && !(window as any).MSStream;
+  const userAgentCheck = /iPad|iPhone|iPod/.test(userAgent) && !(window as any).MSStream;
+  const iPadSpecificCheck = navigator.platform === "MacIntel" && navigator.maxTouchPoints > 1;
+  return userAgentCheck || iPadSpecificCheck;
 }
